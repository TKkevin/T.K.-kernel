# TuesdayOS Git Attributes

# Auto line endings
* text=auto

# Shell scripts
*.sh text eol=lf

# Binary files
*.o binary
*.a binary
*.elf binary
*.bin binary

# Source code
*.c text eol=lf diff=c
*.h text eol=lf diff=c
*.asm text eol=lf
*.s text eol=lf

# Build files
Makefile text eol=lf
*.mk text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
